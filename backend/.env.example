# --- Database ---
DATABASE_URL=postgres://user:pass@host/openhouse-direct-portal
PROPERTIES_DB_URL=postgres://user:pass@host/properties

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
ALLOWED_EMAIL_DOMAIN=openhouse.in

# --- Apps Script push sync ---
# Shared secret. Apps Script sends this in the X-Sync-Token header.
SYNC_TOKEN=change-me-cron-shared-secret

# --- Forms app integration ---
FORMS_APP_URL=https://backend-form.onrender.com
INTERNAL_API_KEY=shared-with-forms-app

# --- Misc ---
FRONTEND_ORIGIN=http://localhost:5173
LOG_LEVEL=INFO
