# Google OAuth client id (real login). Leave blank to use the dev sign-in
# while the backend / OAuth are not yet wired up.
VITE_GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Base URL for the API. Blank = same-origin (/api proxied by Vite in dev).
VITE_API_BASE=

# Mock fallback. When "true" (default while there is no backend), any /api call
# that fails to reach a server is answered from the in-memory mock dataset so
# the UI is fully browsable. Set to "false" once the real backend is up.
VITE_USE_MOCKS=true
